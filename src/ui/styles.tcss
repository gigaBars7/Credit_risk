#app {
    layout: vertical;
    width: 100%;
    height: 1fr;
    padding: 1;
}

.content {
    background: $surface;
}

#main_block {
    layout: vertical;
    height: 1fr;
}

#features_list {
    layout: vertical;
    height: 1fr;
    overflow-y: auto;
}

.feature {
    layout: horizontal;
    width: 1fr;
    height: 3;
    padding: 0 1;
    margin: 1;
}

.feature_label {
    width: auto;
    height: 1fr;
    margin-right: 1;
    content-align: left middle;
}

.feature_input {
    width: 24;
}

#result_content {
    layout: vertical;
    height: auto;
    margin-top: 1;
}

#result_row {
    layout: horizontal;
    width: 100%;
    height: auto;
    padding: 1;
}

#result_button {
    width: auto;
    height: 1;
    align: center middle;
}

#result_values {
    layout: horizontal;
    width: 1fr;
    height: auto;
    margin-left: 1;
}

#rating_value {
    height: 1;
    content-align: left middle;
}

#status_value {
    width: 1fr;
    height: 1;
    margin-left: 1;
    content-align: left middle;
}

.status-minimal {
    color: $success-darken-2;
}

.status-low {
    color: $success-darken-1;
}

.status-moderate {
    color: $warning-darken-2;
}

.status-elevated {
    color: $warning-darken-1;
}

.status-bad {
    color: $error-darken-2;
}

.status-high {
    color: $error-darken-1;
}

.status-critical {
    color: $error;
}
